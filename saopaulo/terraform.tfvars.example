# ============================================
# SÃO PAULO Configuration — Copy to terraform.tfvars and fill in your values
# ============================================

# Project Settings
project_name = "liberdade"
aws_region   = "sa-east-1"

# Network Settings
vpc_cidr             = "10.2.0.0/16"
public_subnet_cidrs  = ["10.2.1.0/24", "10.2.2.0/24"]
private_subnet_cidrs = ["10.2.101.0/24", "10.2.102.0/24"]
azs                  = ["sa-east-1a", "sa-east-1c"]

# EC2 Settings
ec2_ami_id        = "ami-REPLACE_ME"   # Amazon Linux 2023 AMI for sa-east-1
ec2_instance_type = "t3.micro"

# RDS Settings — NOT USED (no database in São Paulo)
# Kept to satisfy variable declarations in shared main.tf
db_engine         = "mysql"
db_instance_class = "db.t3.micro"
db_name           = "labdb"
db_username       = "admin"
db_password       = "REPLACE_ME"

# Monitoring
sns_email_endpoint = "your-email@example.com"
